    {"role": "mio", "role_label": "澪", "line_index": 80, "phase": 4, "voice_tags": "breath_heavy, whisper, pace_slow, broken, pitch_low", "text": "……あつい……先生が、しみる……"},
    {"role": "mio", "role_label": "澪", "line_index": 81, "phase": 4, "voice_tags": "whisper, breath_heavy, pace_slow",                    "text": "……あったかい、です。"},
    {"role": "mio", "role_label": "澪", "line_index": 82, "phase": 4, "voice_tags": "breath_heavy, whisper, pace_slow, broken",            "text": "……私……13歳……"},
    {"role": "mio", "role_label": "澪", "line_index": 83, "phase": 4, "voice_tags": "whisper, broken, pitch_low, pace_slow, breath_heavy", "text": "……私……13歳……"},
    {"role": "mio", "role_label": "澪", "line_index": 84, "phase": 4, "voice_tags": "whisper, broken, pitch_low, pace_slow",               "text": "……先生のこと、忘れられ、ない、です……"},
    {"role": "mio", "role_label": "澪", "line_index": 85, "phase": 5, "voice_tags": "pace_slow, whisper",                                  "text": "……はい。先生に、ぜんぶ、渡して、しまいました。"},
    {"role": "mio", "role_label": "澪", "line_index": 86, "phase": 5, "voice_tags": "pitch_low, pace_slow, whisper",                       "text": "先生、観察日誌、つけていただけますか。"},
    {"role": "mio", "role_label": "澪", "line_index": 87, "phase": 5, "voice_tags": "pitch_low, whisper, broken",                          "text": "どうして。"},
    {"role": "mio", "role_label": "澪", "line_index": 88, "phase": 5, "voice_tags": "broken, whisper, pitch_high",                         "text": "……先生、ずるいです。"},
    {"role": "mio", "role_label": "澪", "line_index": 89, "phase": 5, "voice_tags": "broken, whisper, pace_slow",                          "text": "……先生のこと、忘れられ、なくなりました。"},
    {"role": "mio", "role_label": "澪", "line_index": 90, "phase": 5, "voice_tags": "pace_slow, pitch_low, whisper",                       "text": "先生、またのお越しを、お待ちしております。"}
